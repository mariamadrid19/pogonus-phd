INTERPROSCAN_BIN="${INTERPROSCAN_ROOT}/interproscan.sh"
INTERPROSCAN_VERSION="5.77-108.0"
INTERPROSCAN_SOURCE="local_install"

# 05_diamond.sh
# Uses DIAMOND from the eggnog conda environment
SWISSPROT_FASTA="${DATABASES_DIR}/uniprot_swissprot/uniprot_sprot.fasta"
SWISSPROT_DB_PREFIX="${DATABASES_DIR}/uniprot_swissprot/uniprot_sprot"

# 06a_merge_annotations.py
MERGE_SCRIPT="${SCRIPTS_DIR}/06a_merge_annotations.py"
MERGE_REQUIREMENTS="python3 (standard library only)"

# 06b_merge.sh
MERGE_SLURM="${SCRIPTS_DIR}/06b_merge.sh"

# 07_make_annotated_gtf.py
ANNOTATED_GTF_SCRIPT="${SCRIPTS_DIR}/07_make_annotated_gtf.py"
ANNOTATED_GTF_REQUIREMENTS="python3 (standard library only)"

# 08_minimal_annotated_gtf.py
MINIMAL_GTF_SCRIPT="${SCRIPTS_DIR}/08_minimal_annotated_gtf.py"
MINIMAL_GTF_REQUIREMENTS="python3 (standard library only)"

################################################################################
# Databases
################################################################################

# eggNOG databases
