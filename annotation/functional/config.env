# eggNOG-mapper:
# Installed in conda environment: ${EGGNOG_CONDA_ENV}

# DIAMOND:
# Installed in conda environment: ${EGGNOG_CONDA_ENV}

# InterProScan:
# Installed locally, not via conda/module
# Path: ${INTERPROSCAN_ROOT}

# wget / standard shell utilities:
# Provided by system
# Includes: wget, awk, grep, sort, wc, gunzip, tar, mkdir, ln, head, cut, column, less

