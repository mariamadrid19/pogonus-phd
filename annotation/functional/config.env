# 02_busco.sh
BUSCO_BIN="busco"
BUSCO_VERSION="6.0.0"
BUSCO_SOURCE="conda (${BUSCO_CONDA_ENV})"

# BUSCO lineage used
BUSCO_LINEAGE="insecta_odb12"

# 03a_download_eggnog.sh
WGET_BIN="wget"
WGET_SOURCE="system"

# 03b_run_eggnog.sh
EMAPPER_BIN="emapper.py"
EMAPPER_VERSION="2.1.13"
EMAPPER_SOURCE="conda (${EGGNOG_CONDA_ENV})"

DIAMOND_BIN="diamond"
DIAMOND_VERSION="2.0.15"
DIAMOND_SOURCE="conda (${EGGNOG_CONDA_ENV})"

# 04_interproscan.sh
